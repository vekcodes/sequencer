# Database
DATABASE_URL=postgresql://ces:ces@localhost:5432/ces

# Redis (used in Phase 6+ for the send queue)
REDIS_URL=redis://localhost:6379

# API
NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:5173

# Token encryption (Phase 2) - generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Google OAuth (Phase 2) - fill in once Google Cloud project is set up
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_PUBSUB_TOPIC=

# LLM (Phase 7 - reply classification)
ANTHROPIC_API_KEY=
